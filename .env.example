# Freshworks CloudVerse LLM (keys are often JWTs with an exp — renew when you see 401 Unauthorized)
CLOUDVERSE_API_KEY=your-cloudverse-api-key
CLOUDVERSE_BASE_URL=https://cloudverse.freshworkscorp.com/api/v1
# Optional: model id for npm run check:cloudverse smoke request (defaults to config/zeverse.yaml model)
# CLOUDVERSE_TEST_MODEL=anthropic-claude-4-6-opus

# Zeverse server
ZEVERSE_SERVER_PORT=3100

# Base URL of the Zeverse **API** (Express). The Slack bot calls this, not the Vite app.
# Use port 3100 in dev. Do not set this to the UI URL (5173) unless something proxies /api to 3100.
# If you export ZEVERSE_SERVER_URL in the shell to the wrong URL, unset it: env -u ZEVERSE_SERVER_URL npm run dev:slack
ZEVERSE_SERVER_URL=http://127.0.0.1:3100

# Zeverse UI (used by Slack bot for deep-links)
ZEVERSE_UI_URL=http://localhost:5173

# Slack Bot (optional — only needed if running slack-bot/)
# Required bot token scopes: app_mentions:read, chat:write, commands,
#   im:history, im:read, im:write, channels:history, groups:history
# The bot reads full thread history so it can answer contextually.
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_BOT_PORT=3200

# Default repo id for Slack commands / @mentions that omit <repo-id>
ZEVERSE_DEFAULT_REPO_ID=

# Default workflow for @mentions / DMs that omit <workflow>
ZEVERSE_DEFAULT_WORKFLOW=dev

# Comma-separated Slack user IDs allowed to add repos via Slack (add-repo command).
# Leave empty to disable repo-add from Slack entirely. Find user IDs in Slack profiles.
ZEVERSE_REPO_ADMIN_USER_IDS=

# Google service account JSON (for /zeverse-prd — Google Docs read + comment)
# Relative paths are resolved from the repo root (not server/ cwd).
GOOGLE_SERVICE_ACCOUNT_PATH=./config/gcp-service-account.json

# Confluence (Server / Data Center) — for /zeverse-prd when the URL is a Confluence page
CONFLUENCE_BASE_URL=
CONFLUENCE_PAT_TOKEN=

# Freshrelease integration (for fr-card-creator, fr-analyze, fr-task-finisher)
FRESHRELEASE_API_TOKEN=0xsITr-P54DvpumgzmQ7Rw
FRESHRELEASE_WORKSPACE=BILLING

# GitHub (for PR creation / review posting when gh CLI is not available)
GITHUB_TOKEN=
