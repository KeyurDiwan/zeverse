{
  "name": "zeverse",
  "version": "1.0.0",
  "description": "Zeverse — multi-repo AI workflow runner (server + UI + Slack bot).",
  "license": "MIT",
  "author": "Keyur Diwan",
  "homepage": "https://github.com/KeyurDiwan/zeverse#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/KeyurDiwan/zeverse.git"
  },
  "bugs": {
    "url": "https://github.com/KeyurDiwan/zeverse/issues"
  },
  "keywords": [
    "ai",
    "workflow",
    "llm",
    "slack-bot",
    "devtools",
    "cursor",
    "code-review",
    "automation"
  ],
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "server",
    "ui",
    "slack-bot"
  ],
  "scripts": {
    "install:all": "npm install --workspaces --include-workspace-root",
    "dev:server": "npm run dev --workspace=server",
    "dev:ui": "npm run dev --workspace=ui",
    "dev:slack": "npm run dev --workspace=slack-bot",
    "check:zeverse": "node scripts/check-zeverse.cjs",
    "check:cloudverse": "node scripts/check-cloudverse.cjs",
    "build": "npm run build --workspaces --if-present"
  }
}
